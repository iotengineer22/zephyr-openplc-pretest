&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&gpio2 {
	status = "okay";
};

/ {
	aliases {
		plcin1 = &x001_button;
		plcin2 = &x002_button;
		plcout1 = &y001_led;
	};

	gpio_keys {
		compatible = "gpio-keys";
		x001_button: x001 {
			gpios = <&gpio0 0 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "X001";
		};
		x002_button: x002 {
			gpios = <&gpio1 5 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "X002";
		};
	};

	leds {
		compatible = "gpio-leds";
		y001_led: y001 {
			gpios = <&gpio2 0 GPIO_ACTIVE_LOW>;
			label = "Y001";
		};
	};
};